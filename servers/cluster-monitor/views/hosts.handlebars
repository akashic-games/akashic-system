<div id="page-wrapper">
  <div>
    <h2>Show Hosts</h2>
    {{#if hostInfo}}
    <table class="table table-striped">
      <thead>
        <tr>
          <th>ホスト名</th>
          <th>割当中プロセス数</th>
          <th>待機中プロセス数</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
      {{#each hostInfo}}
        <tr>
          <td><a href="/processes?host={{this.host}}">{{this.host}}</a></td>
          <td>{{this.normalProcessCount}}</td>
          <td>{{this.standbyProcessCount}}</td>
          <td>
            <form class="form-inline" action="/processes?host={{this.host}}&from=hosts" method="POST">
              <div class="btn-toolbar" role="toolbar">
                <input type="hidden" name="host" value="{{this.host}}">
                <input type="submit" class="btn btn-info" name="all_normal" value="全て割当開始">
                <input type="submit" class="btn btn-danger" name="all_standby" value="全て割当解除">
              </div>
            </form>
          </td>
        </tr>
      {{/each}}
      </tbody>
      <tfoot>
        <tr>
          <td><strong>全{{totalCounts.host}}件</strong></td>
          <td><strong>全{{totalCounts.normalProcess}}プロセス</strong></td>
          <td><strong>全{{totalCounts.standbyProcess}}プロセス</strong></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
    {{else}}
    <p>not found</p>
    {{/if}}
  </div>
</div>
