{
  "name": "@akashic/cluster-monitor-api-client",
  "version": "5.2.0",
  "description": "cluster monitor info apiを利用するためのクライアント",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "start": "node --version",
    "prepare": "run-s build",
    "pretest": "run-s lint",
    "test": "jest",
    "lint": "run-p lint:*",
    "lint:tslint": "tslint -p tsconfig.test.json",
    "lint:tsc": "tsc -p tsconfig.test.json",
    "fmt": "run-s format",
    "format": "tslint -p tsconfig.test.json --fix",
    "prebuild": "run-s clean",
    "build": "tsc",
    "clean": "run-p clean:*",
    "clean:lib": "shx rm -rf lib/*"
  },
  "files": [
    "lib"
  ],
  "author": "DWANGO Co., Ltd.",
  "license": "MIT",
  "dependencies": {
    "@akashic-system/logger": "^0.1.8",
    "@akashic/cast-util": "^1.0.97",
    "@akashic/rest-client-core": "^5.0.4",
    "@akashic/server-engine-data-types": "^6.0.100",
    "request": "2.88.2"
  },
  "devDependencies": {
    "@akashic-system/jest-config": "^2.0.53",
    "@akashic-system/tsc-config": "^2.0.31",
    "@akashic-system/tslint-config": "^2.0.30",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.7",
    "jest": "29.7.0",
    "npm-run-all2": "6.2.6",
    "shx": "0.4.0",
    "ts-jest": "29.4.6",
    "tslint": "6.1.3",
    "tslint-config-prettier": "1.18.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "preset": "@akashic-system/jest-config",
    "setupFilesAfterEnv": [
      "../../packages/jest-config/jest.setup.js"
    ]
  },
  "publishConfig": {
    "@akashic:registry": "https://registry.npmjs.org/"
  },
  "gitHead": "e016f72c02b6b5bc835106564398d5b2d823e5f1"
}
