{
  "extends": ["@akashic-system/tslint-config"],
  "rules": {
    "prefer-for-of": false,
    "no-shadowed-variable": false,
    "no-any": false,
    "ban-types": false,
    "variable-name": false,
    "only-arrow-functions": false,
    "max-classes-per-file": false,
    "no-var-requires": false
  }
}
