<div id="page-wrapper">
  <div class="content-header">
    <h3>Cluster Master Information</h3>
  </div>
  <table class="table table-striped table-bordered">
    <tbody>
      <tr>
        <td class="col-xs-2">host</td>
        <td class="col-md-10">{{cluster.master.host}}</td>
      </tr>
      <tr>
        <td class="col-xs-2">port</td>
        <td class="col-md-10">{{cluster.master.port}}</td>
      </tr>
      <tr>
        <td class="col-xs-2">number of processes</td>
        <td class="col-md-10">{{cluster.numProcesses}}</td>
      </tr>
      <tr>
        <td class="col-xs-2">number of instances</td>
        <td class="col-md-10">{{cluster.numInstances}}</td>
      </tr>
      <tr>
        <td class="col-xs-2">total capacity</td>
        <td class="col-md-10">{{cluster.capacity.total}}</td>
      </tr>
      <tr>
        <td class="col-xs-2">used capacity</td>
        <td class="col-md-10">{{cluster.capacity.used}}</td>
      </tr>
    </tbody>
  </table>
  <textarea rows={{jsonRows}} disabled style="width:100%;height:100%;resize:none">
{{json}}
  </textarea>
</div>
