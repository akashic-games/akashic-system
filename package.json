{
  "private": true,
  "name": "akashic-system-monorepo",
  "description": "Mono Repository about Akashic",
  "scripts": {
    "start": "lerna run start",
    "prepare": "npm run bootstrap",
    "bootstrap": "run-s \"bootstrap:*\"",
    "bootstrap:husky": "husky",
    "bootstrap:lerna": "run-s bootstrap:lerna:prepare",
    "bootstrap:lerna:prepare": "lerna run prepare",
    "build": "lerna run build",
    "ci-test": "lerna exec --concurrency 1 -- jest --ci -w 70% --coverage=false --env=node --forceExit --passWithNoTests -b 0 --testTimeout=1000 .spec.ts .test.ts",
    "db:migrate": "run-s \"db:migrate:*\"",
    "db:migrate:mysql": "db-migrate -e mysql up:mysql",
    "db:migrate:mongo": "migrate-mongo up -f ./migrations/config/migrate-mongo-config.js",
    "create-s3-buckets": "ts-node ./scripts/create-s3-buckets.ts",
    "db:seed": "node --unhandled-rejections=strict seedings/index.js",
    "test": "run-s lint test:enormous test:small-large",
    "test:enormous": "jest --ci --forceExit -i -c .jest.enormous.json",
    "test:small-large": "jest --ci --forceExit -i -c .jest.json",
    "coverage": "jest --ci --forceExit -i --coverage -c .jest.json",
    "lint": "run-p \"lint:*\"",
    "lint:tslint": "lerna run lint:tslint",
    "lint:prettier": "prettier -l -u \"**/*\"",
    "fmt": "run-s format",
    "format": "run-s \"format:*\"",
    "format:tslint": "lerna run format",
    "format:prettier": "prettier -w -u \"**/*\"",
    "try-connect": "run-p \"try-connect:*\"",
    "try-connect:mysql": "ts-node ./scripts/waitInisializingDB.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akashic-games/akashic-system.git"
  },
  "author": "DWANGO Co., Ltd.",
  "license": "MIT",
  "dependencies": {
    "mysql2": "3.16.3",
    "sequelize": "6.37.8"
  },
  "devDependencies": {
    "@akashic-system/jest-config": "file:packages/jest-config",
    "@akashic-system/tsc-config": "file:packages/tsc-config",
    "@akashic-system/tslint-config": "file:packages/tslint-config",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/config-lerna-scopes": "19.8.1",
    "@types/config": "3.3.5",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.15",
    "@types/sequelize": "4.28.20",
    "@types/shelljs": "0.10.0",
    "@types/winston": "2.4.4",
    "axios": "1.13.6",
    "can-npm-publish": "1.3.6",
    "config": "3.3.12",
    "db-migrate": "0.11.14",
    "db-migrate-mongodb": "1.5.0",
    "db-migrate-mysql": "3.0.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "js-yaml": "4.1.1",
    "lerna": "8.2.4",
    "migrate-mongo": "12.1.3",
    "npm-run-all2": "6.2.6",
    "prettier": "3.8.1",
    "shelljs": "0.10.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tslint": "6.1.3",
    "tslint-config-prettier": "1.18.0",
    "typescript": "5.9.3",
    "winston": "3.19.0"
  },
  "workspaces": [
    "packages/*",
    "servers/*",
    "tests"
  ],
  "packageManager": "yarn@4.12.0"
}
