{
  "name": "@akashic/akashic-system",
  "version": "11.4.0",
  "description": "domain logic of Akashic System (as akashic server side implementations)",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "prepare": "run-s build",
    "start": "node --version",
    "pretest": "run-s lint",
    "test": "jest",
    "lint": "run-p lint:*",
    "lint:tslint": "tslint -p tsconfig.test.json",
    "lint:tsc": "tsc -p tsconfig.test.json",
    "fmt": "run-s format",
    "format": "tslint -p tsconfig.test.json --fix",
    "prebuild": "run-s clean",
    "build": "tsc",
    "clean": "run-p clean:*",
    "clean:lib": "shx rm -rf lib/*"
  },
  "author": "DWANGO Co., Ltd.",
  "license": "MIT",
  "files": [
    "lib"
  ],
  "dependencies": {
    "@akashic-system/logger": "^0.1.8",
    "@akashic/amflow": "3.0.0",
    "@akashic/amflow-message": "^4.2.0",
    "@akashic/amqp-utils": "^2.1.22",
    "@akashic/playlog": "3.1.0",
    "@akashic/redis-client": "1.2.0",
    "@akashic/server-engine-data-types": "^6.0.100",
    "@aws-sdk/client-s3": "3.991.0",
    "@slack/webhook": "6.1.0",
    "fast-deep-equal": "3.1.3",
    "mysql": "2.18.1"
  },
  "peerDependencies": {
    "@types/mysql": "2.15.27"
  },
  "devDependencies": {
    "@akashic-system/jest-config": "^2.0.53",
    "@akashic-system/tsc-config": "^2.0.31",
    "@akashic-system/tslint-config": "^2.0.30",
    "@types/config": "3.3.5",
    "@types/ioredis": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/mongodb": "4.0.7",
    "@types/mysql": "2.15.27",
    "@types/node": "22.19.15",
    "config": "3.3.12",
    "jest": "29.7.0",
    "js-yaml": "4.1.1",
    "npm-run-all2": "6.2.6",
    "shx": "0.4.0",
    "ts-jest": "29.4.6",
    "tslint": "6.1.3",
    "tslint-config-prettier": "1.18.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "preset": "@akashic-system/jest-config",
    "coverageThreshold": {
      "global": {
        "statements": 80
      },
      "./src/Play/PlayRelation/Database.ts": {
        "statements": 75
      },
      "./src/Playlog/PlaylogFixture.ts": {
        "statements": 10
      },
      "./src/Playlog/PlaylogQueueConsumer.ts": {
        "statements": 70
      },
      "./src/Playlog/PlaylogQueue/AMQPPlaylogQueue.ts": {
        "statements": 65
      },
      "./src/Playlog/PlaylogQueue/AMQPPlaylogStoreQueue.ts": {
        "statements": 50
      },
      "./src/Playlog/PlaylogStore/MongoDBStore.ts": {
        "statements": 75
      },
      "./src/Playlog/PlaylogStore/PlaylogArchiveStore/MemoryArchiveStore.ts": {
        "statements": 70
      },
      "./src/Playlog/PlaylogStore/PlaylogArchiveStore/PlaylogS3Store.ts": {
        "statements": 35
      },
      "./src/Playlog/PlaylogStore/PlaylogDatabase/PlaylogDatabase.ts": {
        "statements": 50
      }
    },
    "setupFilesAfterEnv": [
      "../../packages/jest-config/jest.setup.js"
    ]
  },
  "publishConfig": {
    "@akashic:registry": "https://registry.npmjs.org/"
  }
}
