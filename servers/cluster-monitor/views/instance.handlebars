<script src="/js2/admin.js"></script>
<div id="page-wrapper">
  {{#if admin}}
    <h3>Admin Controller</h3>
    <p><a href="#" onclick="instance_stop_onclick({{instance.id}})" class="btn btn-danger">Stop</a></p>
  {{/if}}
  <div class="content-header">
    <h3>Instance #{{instance.id}} Information</h3>
  </div>
  <table class="table table-striped table-bordered">
    <tbody>
      <tr>
        <td class="col-xs-2">status</td>
        <td class="col-md-10"><a href="/instances?status={{instance.status}}">{{instance.status}}</a></td>
      </tr>
      <tr>
        <td class="col-xs-2">game code</td>
        <td class="col-md-10"><a href="/instances?gameCode={{instance.gameCode}}">{{instance.gameCode}}</a></td>
      </tr>
      <tr>
        <td class="col-xs-2">entry point</td>
        <td class="col-md-10"><a href="/instances?entryPoint={{instance.entryPoint}}">{{instance.entryPoint}}</a></td>
      </tr>
      <tr>
        <td class="col-xs-2">process</td>
        <td class="col-md-10"><a href="/instances?processName={{instance.processName}}">{{instance.processName}}</a></td>
      </tr>
      <tr>
        <td class="col-xs-2">region</td>
        <td class="col-md-10">{{instance.region}}</td>
      </tr>
      <tr>
        <td class="col-xs-2">cost</td>
        <td class="col-md-10">{{instance.cost}}</td>
      </tr>
      <tr>
        <td class="col-xs-2">exit code</td>
        <td class="col-md-10">{{instance.exitCode}}</td>
      </tr>
    </tbody>
  </table>
  {{#if instance.modules}}
    <h4>modules</h4>
    {{#each instance.modules}}
      <h5>{{code}}</h5>
      <table class="table table-striped table-bordered">
        <tbody>
          {{#if values.playId}}
            <tr>
              <td class="col-xs-2">play id</td>
              <td class="col-md-10"><a href="/instances?play={{values.playId}}">{{values.playId}}</a></td>
            </tr>
          {{/if}}
          {{#if values.executionMode}}
            <tr>
              <td class="col-xs-2">mode</td>
              <td class="col-md-10">{{values.executionMode}}</td>
            </tr>
          {{/if}}
          {{#if values.handlers}}
            <thead>
              <tr>
                <td class="col-xs-2">type</td>
                <td class="col-xs-2">end point</td>
                <td class="col-md-8">protocol</td>
              </tr>
            </thead>
            {{#each values.handlers}}
              <tr>
                <td class="col-xs-2">{{type}}</td>
                <td class="col-xs-2">{{endpoint}}</td>
                <td class="col-md-8">{{protocol}}</td>
              </tr>
            {{/each}}
          {{/if}}
          {{#if values.gameConfigurations}}
            <tr>
            {{#each values.gameConfigurations}}
              <td>{{this}}</td>
            {{/each}}
            </tr>
          {{/if}}
          {{#if values.videoPublishUri}}
            <tr>
              <td class="col-xs-2">video publish uri</td>
              <td class="col-md-10">{{values.videoPublishUri}}</td>
            </tr>
          {{/if}}
          {{#if values.videoFrameRate}}
            <tr>
              <td class="col-xs-2">video frame rate</td>
              <td class="col-md-10">{{values.videoFrameRate}}</td>
            </tr>
          {{/if}}
        </tbody>
      </table>
    {{/each}}
  {{/if}}
  <h4>json</h4>
  <textarea rows={{jsonRows}} disabled style="width:100%;height:100%;resize:none">
{{json}}
  </textarea>
</div>
